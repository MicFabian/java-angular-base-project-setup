{
  "name": "base-project",
  "version": "0.1.0",
  "license": "MIT",
  "engines": {
    "node": ">=22.15.1 <23"
  },
  "scripts": {
    "build": "nx run-many -t build && ./scripts/gradlew-local.sh :server:build",
    "lint": "nx run-many -t lint",
    "test": "nx run-many -t test && ./scripts/gradlew-local.sh :server:test",
    "verify": "./scripts/verify-all.sh",
    "verify:e2e": "./scripts/verify-all.sh --with-e2e",
    "verify:ci": "./scripts/pnpmw.sh run verify && ./scripts/pnpmw.sh run test:server:integration",
    "doctor": "./scripts/doctor.sh",
    "doctor:db": "./scripts/doctor.sh --require-docker",
    "setup": "./scripts/bootstrap.sh",
    "setup:db": "./scripts/bootstrap.sh --with-db",
    "setup:verify": "./scripts/bootstrap.sh --verify",
    "setup:full": "./scripts/bootstrap.sh --with-db --verify",
    "personalize": "./scripts/personalize-template.sh",
    "format": "./scripts/pnpmw.sh run format:frontend && ./scripts/pnpmw.sh run format:backend",
    "format:check": "./scripts/pnpmw.sh run format:frontend:check && ./scripts/pnpmw.sh run format:backend:check",
    "format:frontend": "./scripts/pnpmw.sh prettier --cache --ignore-unknown --write .",
    "format:frontend:check": "./scripts/pnpmw.sh prettier --check --ignore-unknown .",
    "format:backend": "./scripts/gradlew-local.sh :server:spotlessApply",
    "format:backend:check": "./scripts/gradlew-local.sh :server:spotlessCheck",
    "format:nx": "nx format:write",
    "graph": "nx graph",
    "start:client": "nx serve client",
    "build:client": "nx build client",
    "test:client": "nx test client",
    "e2e:client": "nx e2e client-e2e",
    "start:server": "./scripts/gradlew-local.sh :server:bootRun",
    "build:server": "./scripts/gradlew-local.sh :server:build",
    "test:server": "./scripts/gradlew-local.sh :server:test",
    "test:server:snapshots:update": "./scripts/gradlew-local.sh :server:updateSnapshots",
    "test:server:integration": "./scripts/gradlew-local.sh :server:integrationTest",
    "test:server:architecture": "./scripts/gradlew-local.sh :server:test --tests 'com.example.baseproject.api.architecture.*'",
    "scaffold:backend-feature": "./scripts/new-backend-feature.sh",
    "infra:up": "docker compose -f docker/compose.yaml up -d db",
    "infra:down": "docker compose -f docker/compose.yaml down",
    "skills:verify": "./scripts/verify-skills.sh",
    "skills:list": "./scripts/skills-cli.sh list -a codex",
    "skills:find": "./scripts/skills-cli.sh find",
    "skills:add": "./scripts/skills-cli.sh add",
    "skills:restore": "./scripts/skills-cli.sh experimental_install",
    "skills:check": "./scripts/skills-cli.sh check",
    "skills:update": "./scripts/skills-cli.sh update"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "~21.2.6",
    "@angular/compiler": "~21.2.6",
    "@angular/core": "~21.2.6",
    "@angular/forms": "~21.2.6",
    "@angular/platform-browser": "~21.2.6",
    "@angular/router": "~21.2.6",
    "rxjs": "~7.8.2"
  },
  "devDependencies": {
    "@angular-devkit/core": "~21.2.3",
    "@angular-devkit/schematics": "~21.2.3",
    "@angular/build": "~21.2.3",
    "@angular/cli": "~21.2.3",
    "@angular/compiler-cli": "~21.2.6",
    "@angular/language-service": "~21.2.6",
    "@eslint/js": "^9.39.4",
    "@nx/angular": "22.6.1",
    "@nx/devkit": "22.6.1",
    "@nx/eslint": "22.6.1",
    "@nx/eslint-plugin": "22.6.1",
    "@nx/js": "22.6.1",
    "@nx/playwright": "22.6.1",
    "@nx/web": "22.6.1",
    "@nx/workspace": "22.6.1",
    "@playwright/test": "^1.58.2",
    "@schematics/angular": "~21.2.3",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.21",
    "@swc/helpers": "~0.5.19",
    "@typescript-eslint/utils": "^8.57.2",
    "@vitest/coverage-v8": "^4.1.1",
    "angular-eslint": "^21.3.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-playwright": "^1.8.3",
    "jsdom": "^27.1.0",
    "nx": "22.6.1",
    "prettier": "~3.6.2",
    "tslib": "^2.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.0.8"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
